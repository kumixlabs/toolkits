{
  "name": "@kumix/email",
  "version": "0.1.2",
  "description": "Email templates and sending utilities for SaaS applications.",
  "author": "Kumix Labs <hai@kumix.io>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "default": "./dist/helpers.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "rimraf .turbo coverage dist node_modules",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "types:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "homepage": "https://github.com/kumixlabs/toolkits",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kumixlabs/toolkits.git",
    "directory": "packages/email"
  },
  "bugs": {
    "url": "https://github.com/kumixlabs/toolkits/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kumix",
    "email",
    "smtp",
    "nodemailer",
    "resend"
  ],
  "devDependencies": {
    "@kumix/tsconfig": "catalog:",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-email": "^6.6.9",
    "resend": "^6.17.2",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "nodemailer": ">=9.0.0",
    "react": ">=18.0.0 || >=19.0.0-rc.0",
    "react-email": ">=6.6.0",
    "resend": ">=6.15.0"
  },
  "peerDependenciesMeta": {
    "nodemailer": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-email": {
      "optional": true
    },
    "resend": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
